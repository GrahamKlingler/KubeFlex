# N-Body MPI simulation image with CRIU 4.1.1 support
FROM ubuntu:22.04

USER root
ENV DEBIAN_FRONTEND=noninteractive

# Build CRIU 4.1.1 from source
RUN apt-get update && apt-get install -y \
    git build-essential pkg-config \
    libprotobuf-dev libprotobuf-c-dev protobuf-c-compiler protobuf-compiler \
    python3-protobuf libnl-3-dev libcap-dev uuid-dev libaio-dev \
    libnet-dev libgnutls28-dev iproute2 libnftables-dev nftables \
    tini \
    && git clone https://github.com/checkpoint-restore/criu.git /tmp/criu \
    && cd /tmp/criu && git checkout v4.1.1 \
    && make -j$(nproc)

RUN cp /tmp/criu/criu/criu /usr/local/sbin/criu \
    && chmod 755 /usr/local/sbin/criu \
    && setcap cap_sys_admin+eip /usr/local/sbin/criu \
    && setcap cap_checkpoint_restore+eip /usr/local/sbin/criu \
    && rm -rf /tmp/criu

# Install MPI, build tools, and SSH
RUN apt-get update && apt-get install -y \
    cmake g++ \
    libopenmpi-dev openmpi-bin \
    openssh-server openssh-client \
    && rm -rf /var/lib/apt/lists/*

# Configure SSH for MPI communication between pods
RUN mkdir -p /var/run/sshd \
    && ssh-keygen -A \
    && ssh-keygen -t rsa -N "" -f /root/.ssh/id_rsa \
    && cp /root/.ssh/id_rsa.pub /root/.ssh/authorized_keys \
    && chmod 600 /root/.ssh/authorized_keys \
    && echo "StrictHostKeyChecking no" >> /etc/ssh/ssh_config \
    && echo "UserKnownHostsFile /dev/null" >> /etc/ssh/ssh_config \
    && echo "PermitRootLogin yes" >> /etc/ssh/sshd_config \
    && echo "StrictModes no" >> /etc/ssh/sshd_config

# Copy N-body source code
COPY ./tests/antibody-sim/MPI-Workload-main/nbody/ /app/nbody/
COPY ./tests/antibody-sim/MPI-Workload-main/utils/ /app/utils/

# Build both MPI and no-MPI versions of the N-body simulation
WORKDIR /app/nbody
RUN cmake CMakeLists.txt && make

# Copy wrapper script for CRIU migration testing
COPY ./tests/antibody-sim/run_nbody.sh /tmp/run_nbody.sh
RUN chmod +x /tmp/run_nbody.sh

# Create required directories
RUN mkdir -p /tmp/checkpoints /results /cgroup-yard /script-data \
    && chmod 777 /tmp/checkpoints /results /script-data

VOLUME ["/tmp/checkpoints"]
VOLUME ["/results"]

WORKDIR /app/nbody

ENTRYPOINT ["/usr/bin/tini", "--"]
