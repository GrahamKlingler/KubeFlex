FROM python:3.9-slim

WORKDIR /app

# Copy requirements and install
COPY build/main_req.txt .
RUN pip install -r main_req.txt

# Copy the Python code from controller/
COPY controller/controller/ ./controller/
COPY controller/db/ ./db/
COPY controller/migrator/ ./migrator/

# Run the script
CMD ["python3", "controller/main.py"]