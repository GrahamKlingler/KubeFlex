FROM debian:bullseye-slim

# Install required packages
RUN apt-get update && apt-get install -y \
    build-essential \
    gcc \
    make \
    htop \
    procps \
    psmisc \
    && rm -rf /var/lib/apt/lists/*

# Create directory for test files
WORKDIR /test

# Copy the stress test source
COPY stress_test.c /test/

# Compile the stress test
RUN gcc -o stress_test stress_test.c -pthread

# Remove the CMD and ENV as they'll be controlled by the manifest